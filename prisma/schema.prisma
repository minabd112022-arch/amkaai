generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id             String   @id @default(cuid())
  clerkId        String   @unique
  email          String?
  plan           String   @default("FREE")
  credits        Int      @default(10)

  // 💳 Stripe
  customerId     String?  @unique
  subscriptionId String?  @unique

  createdAt      DateTime @default(now())

  // 🔗 Relations
  images Image[]
  videos Video[]
  voices Voice[]
  payments Payment[]
  usage Usage[]
  abandonedCheckouts AbandonedCheckout[]
  manualPayments ManualPayment[]
  notifications Notification[]   // 🔔 NEW
}

model Payment {
  id        String   @id @default(cuid())
  amount    Float
  currency  String
  userId    String
  stripeId  String?  @unique
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [clerkId])

  @@index([userId])
}

model Usage {
  id        String   @id @default(cuid())
  type      String
  cost      Int
  userId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [clerkId])

  @@index([userId])
}

model Image {
  id        String   @id @default(cuid())
  url       String
  prompt    String
  userId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [clerkId])
}

model Video {
  id        String   @id @default(cuid())
  url       String?
  prompt    String
  status    String   @default("pending")
  userId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [clerkId])
}

model Voice {
  id        String   @id @default(cuid())
  url       String
  text      String
  userId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [clerkId])
}

model AbandonedCheckout {
  id              String   @id @default(cuid())
  userId          String
  email           String
  checkoutUrl     String
  stripeSessionId String   @unique
  recovered       Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [clerkId])
}

//////////////////////////////////////////////////
// 🔔 NOTIFICATIONS (جديد)
//////////////////////////////////////////////////

model Notification {
  id        String   @id @default(cuid())
  userId    String

  title     String
  message   String

  read      Boolean  @default(false)

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [clerkId])

  @@index([userId])
}

//////////////////////////////////////////////////
// 🔥 PRO ANTI-FRAUD PAYMENT SYSTEM
//////////////////////////////////////////////////

model ManualPayment {
  id        String   @id @default(cuid())

  userId    String
  plan      String   // PRO | PREMIUM

  method    String   // USDT | BARIDIMOB
  amount    Float
  currency  String   // 🔥 NEW (USDT / DZD)

  // 📸 Screenshot
  screenshotUrl String?

  // 🔐 Anti-fraud
  transactionId String?   @unique   // 🔥 مهم جدًا لمنع التكرار
  imageHash     String?   @unique   // 🔥 يمنع إعادة نفس الصورة

  ipAddress     String?
  device        String?

  // 🧠 AI
  aiScore       Float?
  aiRawText     String?
  verified      Boolean   @default(false)

  // 🚦 Status
  status        String   @default("PENDING") 
  // PENDING | AUTO_APPROVED | APPROVED | REJECTED | FLAGGED

  // ⚠️ Risk
  riskLevel     String?  // LOW | MEDIUM | HIGH

  // 👤 Admin tracking
  approvedBy    String?
  rejectedBy    String?
  rejectReason  String?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user User @relation(fields: [userId], references: [clerkId])

  // 🚀 Indexes
  @@index([userId])
  @@index([status])
  @@index([createdAt])
}